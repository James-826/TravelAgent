APP_NAME=智能旅行助手
APP_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Optional: official AMap MCP bridge endpoint.
AMAP_MCP_ENDPOINT=
AMAP_MCP_COMMAND=npx.cmd
AMAP_MCP_ARGS=-y @amap/amap-maps-mcp-server
AMAP_MAPS_API_KEY=
AMAP_MCP_SEARCH_TOOL=maps_text_search
AMAP_MCP_WEATHER_TOOL=maps_weather
AMAP_MCP_DETAIL_TOOL=maps_search_detail

# Server-side only. Do not put this key in frontend/.env.
UNSPLASH_ACCESS_KEY=
UNSPLASH_APP_NAME=travel_agent

# OpenAI-compatible LLM config, used when we wire agent prompts to model calls.
LLM_PROVIDER=aihubmix
LLM_BASE_URL=https://aihubmix.com/v1
LLM_API_KEY=
LLM_MODEL=xiaomi-mimo-v2-omni-free
